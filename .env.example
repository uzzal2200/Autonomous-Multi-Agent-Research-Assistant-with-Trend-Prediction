# ResearchAI Environment Variables
# Copy this file to .env and fill in your values

# Semantic Scholar API (free tier, optional key for higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# HuggingFace (free, optional for private models)
HUGGINGFACE_API_TOKEN=

# Application Settings
LOG_LEVEL=INFO
CACHE_ENABLED=true
MAX_PAPERS_PER_QUERY=50
